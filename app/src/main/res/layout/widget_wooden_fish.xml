<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_wooden_fish_bg"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvMeritCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="20sp"
        android:textColor="#FFD700"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/merit"
        android:textSize="12sp"
        android:textColor="#FFD700"
        android:layout_marginBottom="12dp" />

    <ImageView
        android:id="@+id/ivWoodenFish"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:src="@drawable/ic_wooden_fish"
        android:scaleType="fitCenter"
        android:contentDescription="@string/wooden_fish_widget" />

    <Button
        android:id="@+id/btnReset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reset"
        android:textSize="12sp"
        android:backgroundTint="#8B4513"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp" />

</LinearLayout>
